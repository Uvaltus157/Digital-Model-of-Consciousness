  "goal": "Demonstrate the full path from ready dynamic object slot to 3D Gaussian reconstruction, 4D deformation/playback, Inner Object window, and Inner Object Open3D JSON-RPC window.",
  "output_policy": {
    "format": "[STAGE] <stage_id> status=<running|ok|failed|repair_applied> comment=<short explanation>",
