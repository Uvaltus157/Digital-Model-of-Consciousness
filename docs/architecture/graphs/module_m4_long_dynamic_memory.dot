digraph G {
  graph [layout=neato, splines=true, overlap=false];

  "m1_obj" [label="M1 inner_object", color="#255c99", fillcolor="#e8f1ff", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="z_obj\nslot info\nselected slot", width="1.889", height="0.889", pos="60.00,260.00!"];
  "passport_runtime" [label="DynamicObjectPassportRuntimeMixin", color="#a46413", fillcolor="#fff2d9", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="ensures passport manager\nupdates/reproduces passport", width="2.333", height="1.278", pos="256.00,134.00!"];
  "passport_manager" [label="DynamicObjectPassportManager", color="#a46413", fillcolor="#fff8ea", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="OBJ token\nslot ↔ identity\nidentity over time\nreplay inner world", width="2.333", height="1", pos="396.00,24.00!"];
  "long_runtime" [label="LongDynamicMemoryRuntimeMixin", penwidth="2.0", fontsize="10", shape="ellipse", description="compute_long_dynamic_memory(obs,out)\nwrites out['long_dynamic_memory']", width="2.333", height="1", pos="656.00,184.00!"];
  "controller" [label="LongDynamicMemory controller", color="#6840a1", fillcolor="#f0eaff", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="stability / novelty / similarity\ndynamic_memory_gate\nreplay_z", width="2.333", height="1.278", pos="696.00,-6.00!"];
  "context" [label="dynamic_identity_context", color="#6840a1", fillcolor="#f7f2ff", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="0.40 z_obj\n0.30 replay_z\n0.20 focus_context\n0.10 event replay context\n0.10 scalar tail", width="2.611", height="1", pos="-6.00,-136.00!"];
  "packet" [label="out['long_dynamic_memory']", penwidth="2.0", fontsize="10", shape="ellipse", description="identity_token\ndynamic_identity_context\nidentity_* fields\npassport_count/slot\nselected_sentence\nreplay_z", width="3.167", height="1.278", pos="260.00,-220.00!"];
  "mirror" [label="mirror to inner_object", color="#a46413", fillcolor="#fff8ea", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="m4_identity_token\nm4_identity_source\nm4_* tensors", width="2.333", height="1.278", pos="540.00,-280.00!"];
  "roles" [label="M4abc roles", color="#a38925", fillcolor="#fffbea", penwidth="2.0", fontsize="10", style="filled", shape="ellipse", description="M4a: object temporal trace\nM4c: passport/OBJ token\nM4b: world/scenario context\n(currently one implementation)", width="1.889", height="0.889", pos="100.00,20.00!"];

  "m1_obj" -> "long_runtime" [label="out['inner_object']", xdot_curve="-0.05", penwidth="2.0", fontsize="9"];
  "long_runtime" -> "passport_runtime" [label="ensure manager", xdot_curve="0.12", penwidth="2.0", fontsize="9"];
  "passport_runtime" -> "passport_manager" [label="observe/select"];
  "passport_manager" -> "controller" [label="passport info", xdot_curve="-0.17", penwidth="2.0", fontsize="9"];
  "controller" -> "context" [label="make_context", xdot_curve="0.07", penwidth="2.0", fontsize="9"];
  "context" -> "packet" [label="packet"];
  "packet" -> "mirror" [label="mirror fields"];
  "roles" -> "passport_manager" [style="dashed", label="M4c"];
  "roles" -> "context" [style="dashed", label="M4b"];
  "roles" -> "m1_obj" [style="dashed", label="M4a input"];
}
