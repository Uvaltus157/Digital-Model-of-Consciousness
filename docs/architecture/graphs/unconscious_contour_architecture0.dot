  subgraph "cluster_m8" {
    label="M8 Status / Trace";
    color="#607080";
    fillcolor="#f1f3f5";
    style="filled";
    xdot_pad_left="53.00";
    xdot_pad_top="47.00";
    xdot_pad_right="39.00";
    xdot_pad_bottom="11.00";
    penwidth="2.0";
    fontsize="10";
    "status" [label="ModuleStatusRuntimeMixin\nmodule debug status bus", color="#607080", shape="ellipse", width="2", height="1.194", pos="260.00,-1400.00!", penwidth="2.0", fontsize="10"];
    "trace" [label="UnconsciousLoopTraceRuntimeMixin\nM2/M13/unconscious traces", color="#607080", shape="ellipse", width="2.056", height="1.278", pos="460.00,-1440.00!", penwidth="2.0", fontsize="10"];
  }

  subgraph "cluster_training" {
    label="Replay buffer / training";
    color="#6f7785";
    fillcolor="#ffffff";
    style="filled";
    xdot_pad_left="32.00";
    xdot_pad_top="48.00";
    xdot_pad_right="32.00";
    xdot_pad_bottom="48.00";
    penwidth="2.0";
    fontsize="10";
    "replaybuf" [label="replay.add(...)\nobs/action/state traces", color="#6f7785", shape="ellipse", width="1.889", height="0.889", pos="1120.00,-1020.00!", penwidth="2.0", fontsize="10"];
    "training" [label="TrainingRuntimeMixin\nuses replay buffer\nnot M2 replay selector", color="#6f7785", shape="ellipse", width="1.889", height="0.889", pos="1280.00,-1020.00!", penwidth="2.0", fontsize="10"];
  }


  "sleep_gates" -> "m5_model" [label="gated obs", color="#2c7a4b", ltail="cluster_input", lhead="cluster_m5", penwidth="2.0", fontsize="9", xdot_curve="0.16"];
  "sleep_gates" -> "m1_runtime" [label="gated obs", color="#255c99", ltail="cluster_input", lhead="cluster_m1", penwidth="2.0", fontsize="9", xdot_curve="0.16"];
  "m5_model" -> "m1_runtime" [label="out + obs", color="#255c99", ltail="cluster_m5", lhead="cluster_m1"];
  "m5_model" -> "action" [label="action fields", color="#4d4d4d", ltail="cluster_m5", lhead="cluster_m3"];
  "m1_slots" -> "passport" [label="slot/z_obj identity evidence", color="#a46413", ltail="cluster_m1", lhead="cluster_m4"];
  "m1_slots" -> "longmem" [label="inner_object.z_obj", color="#6840a1", ltail="cluster_m1", lhead="cluster_m4"];
  "m5_focus" -> "m4_context" [label="focus_context", color="#6840a1", ltail="cluster_m5", lhead="cluster_m4"];
  "m2_packet" -> "m4_context" [label="event_dream_replay.replay_context", color="#6840a1", ltail="cluster_m2", lhead="cluster_m4", xdot_curve="-0.14", penwidth="2.0", fontsize="9"];
  "m4_packet" -> "m13_retrieve" [label="M4 identity context", color="#4d6668", ltail="cluster_m4", lhead="cluster_m13"];
  "m4_packet" -> "m2_runtime" [label="M4 context", color="#6840a1", ltail="cluster_m4", lhead="cluster_m2"];
  "m5_model" -> "emotion" [label="values / imagined / reward context", color="#a43656", ltail="cluster_m5", lhead="cluster_m11", penwidth="7.0", fontsize="9", xdot_curve="0.16"];
  "affect" -> "m13_retrieve" [label="affect context", color="#4d6668", ltail="cluster_m11", lhead="cluster_m13", xdot_tail_anchor="58.22,16.54", penwidth="2.0", fontsize="9", xdot_curve="0.12"];
  "affect" -> "m2_runtime" [label="dream pressure / salience", color="#967a11", ltail="cluster_m11", lhead="cluster_m2", xdot_tail_anchor="-58.38,16.41", penwidth="7.0", fontsize="9", xdot_curve="0.16"];
  "m13_packet" -> "m2_runtime" [label="M13 context", color="#967a11", ltail="cluster_m13", lhead="cluster_m2", xdot_head_anchor="134.00,-1.91", penwidth="2.0", fontsize="9", xdot_curve="0.16"];
  "m13_packet" -> "passport" [label="episode links / event memory", color="#a46413", ltail="cluster_m13", lhead="cluster_m4", xdot_curve="0.36", penwidth="2.0", fontsize="9", xdot_head_anchor="47.33,-46.00", xdot_tail_anchor="-67.70,3.02"];
  "m2_seed" -> "seed_bus" [label="priority #2 replay seed", color="#4457aa", ltail="cluster_m2", lhead="cluster_m5", penwidth="7.0", fontsize="9", xdot_curve="0.16"];
  "motor" -> "obs" [label="body movement / next observe", color="#ef2929", ltail="cluster_m3", lhead="cluster_input", xdot_head_anchor="87.00,-8.96", penwidth="2.0", fontsize="9", xdot_curve="0.64", xdot_tail_anchor="66.41,-6.88"];
  "sleep_gates" -> "guard" [label="sleep mode flag", color="#526aa8", style="dashed", ltail="cluster_input", lhead="cluster_m3", xdot_curve="0.12", penwidth="2.0", fontsize="9"];
  "m1_slots" -> "status" [label="M1 status", color="#607080", style="dotted", ltail="cluster_m1", lhead="cluster_m8"];
  "m4_packet" -> "status" [label="M4 status", color="#607080", style="dotted", ltail="cluster_m4", lhead="cluster_m8"];
  "affect" -> "status" [label="M11 status", color="#607080", style="dotted", ltail="cluster_m11", lhead="cluster_m8"];
  "m13_packet" -> "trace" [label="M13 trace", color="#607080", style="dotted", ltail="cluster_m13", lhead="cluster_m8", xdot_curve="-0.21", penwidth="2.0", fontsize="9"];
  "m2_packet" -> "trace" [label="M2 trace", color="#607080", style="dotted", ltail="cluster_m2", lhead="cluster_m8", xdot_curve="-0.19", penwidth="2.0", fontsize="9"];
  "motor" -> "status" [label="M3 status", color="#607080", style="dotted", ltail="cluster_m3", lhead="cluster_m8", penwidth="2.0", fontsize="9", xdot_curve="0.16", xdot_tail_anchor="-50.87,-21.24"];
  "seed_bus" -> "status" [label="M5 seed status", color="#607080", style="dotted", ltail="cluster_m5", lhead="cluster_m8", penwidth="2.0", fontsize="9", xdot_curve="0.16"];
  "obs" -> "replaybuf" [label="obs traces", color="#6f7785", ltail="cluster_input", lhead="cluster_training", xdot_curve="-0.38", penwidth="2.0", fontsize="9"];
  "motor" -> "replaybuf" [label="motor traces", color="#6f7785", ltail="cluster_m3", lhead="cluster_training"];
  "m13_write" -> "replaybuf" [label="episode write near tail", color="#4d6668", ltail="cluster_m13", lhead="cluster_training", xdot_curve="-0.08", penwidth="2.0", fontsize="9"];
}
